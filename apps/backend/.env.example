# ── Backend (Express + Prisma) ───────────────────────────────────────────────

# Cadena de conexión a PostgreSQL (runtime).
# Local (docker-compose): postgresql://acme_admin:acme_password@localhost:5444/acme_finanzas
# Producción (Supabase): pooler en modo transacción (puerto 6543):
#   postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://acme_admin:acme_password@localhost:5444/acme_finanzas"

# Conexión directa para migraciones/seed de Prisma (Supabase: puerto 5432, session mode).
# En local podés apuntarla a la misma URL que DATABASE_URL.
DIRECT_URL="postgresql://acme_admin:acme_password@localhost:5444/acme_finanzas"

# Clave para firmar los JWT. Generá una aleatoria y larga en producción.
# Ej: openssl rand -base64 48
JWT_SECRET="change-me-in-production"

# Puerto del servidor (opcional, default 4000)
PORT=4000

# Admin que se crea automáticamente al arrancar (datos de demo).
ADMIN_EMAIL="admin@acme.com"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Admin"
